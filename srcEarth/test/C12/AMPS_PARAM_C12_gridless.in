! ═══════════════════════════════════════════════════════════════
! AMPS SEP geospace validation test C12
! Particle-mover cross-validation against analytical Størmer cutoff
!
! This template is rendered by run_C12.py.  The script replaces the
! __...__ placeholders with the requested altitude shell, latitude sampling,
! energy range, step controls, and selected mover.  The active mover is supplied
! through the command line (-mover <BORIS|RK2|RK4|RK6|GC2|GC4|GC6>), because the
! current parser treats mover keywords as reserved / future input-file support.
! ═══════════════════════════════════════════════════════════════

#CALCULATION_MODE
CALC_TARGET            CUTOFF_RIGIDITY
FIELD_EVAL_METHOD      GRIDLESS

#CUTOFF_RIGIDITY
CUTOFF_EMIN            __CUTOFF_EMIN_MEV__      ! MeV/n
CUTOFF_EMAX            __CUTOFF_EMAX_MEV__      ! MeV/n
CUTOFF_MAX_PARTICLES   500
CUTOFF_NENERGY         80
CUTOFF_SAMPLING        VERTICAL
CUTOFF_MAX_TRAJ_TIME   __MAX_TRACE_TIME__

#PARTICLE_SPECIES
SPECIES                PROTON
CHARGE                 1
MASS_AMU               1.0073

#BACKGROUND_FIELD
FIELD_MODEL            DIPOLE
DIPOLE_MOMENT          1.00
DIPOLE_TILT            0.0

#DOMAIN_BOUNDARY
DOMAIN_X_MAX           35.0
DOMAIN_X_MIN           -35.0
DOMAIN_Y_MAX           35.0
DOMAIN_Y_MIN           -35.0
DOMAIN_Z_MAX           35.0
DOMAIN_Z_MIN           -35.0
R_INNER                1.0

#ELECTRIC_FIELD
! No electric field is used in C12.  The reference is a static centered dipole.

#SPECTRUM
SPECTRUM_TYPE          POWER_LAW
SPEC_J0                1.00e+4
SPEC_GAMMA             3.50
SPEC_E0                10.0
SPEC_EMIN              1.0
SPEC_EMAX              1000.0

#OUTPUT_DOMAIN
OUTPUT_MODE            SHELLS
SHELL_COUNT            1
SHELL_ALTS_KM          __SHELL_ALT_KM__
SHELL_RES_DEG          __SHELL_RES_DEG__

#NUMERICAL
DT_TRACE               __DT_TRACE__
MAX_TRACE_TIME         __MAX_TRACE_TIME__
MAX_TRACE_DISTANCE     __MAX_TRACE_DISTANCE_RE__
ADAPTIVE_DT            __ADAPTIVE_DT__

! C12 harness provenance, all passive comments:
! C12_MOVER              __MOVER__
! C12_TARGET_LATS_DEG    __TARGET_LATS_DEG__
! C12_REFERENCE          Analytical Størmer vertical cutoff
! C12_FORMULA            Rc = R0 cos^4(lambda) / r_RE^2

!#END
