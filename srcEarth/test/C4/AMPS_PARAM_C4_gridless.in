! ═══════════════════════════════════════════════════════════════
! AMPS SEP geospace validation test C4
! Mode3D trajectory-exit classifier and invariant diagnostic, Gridless
!
! The Python harness enables CUTOFF_DEBUG_EXIT_LIST_FILE so all selected
! diagnostic trajectories are traced during one AMPS run and written to one
! combined output file for post-run analysis.
! ═══════════════════════════════════════════════════════════════

#CALCULATION_MODE
CALC_TARGET            CUTOFF_RIGIDITY
FIELD_EVAL_METHOD      GRIDLESS

#CUTOFF_RIGIDITY
CUTOFF_EMIN            1.0          ! MeV/n
CUTOFF_EMAX            20000.0      ! MeV/n
CUTOFF_MAX_PARTICLES   500          ! per injection point
CUTOFF_NENERGY         50           ! log-spaced energy bins
CUTOFF_SAMPLING        VERTICAL     ! VERTICAL or ISOTROPIC
CUTOFF_MAX_TRAJ_TIME   600          ! sec; kept consistent with MAX_TRACE_TIME

#PARTICLE_SPECIES
SPECIES                PROTON
CHARGE                 1            ! elementary charge
MASS_AMU               1.0073       ! atomic mass units

#BACKGROUND_FIELD
FIELD_MODEL            DIPOLE
DIPOLE_MOMENT          1.00         ! multiples of M_E
DIPOLE_TILT            0.0          ! deg from GSM Z-axis

#DOMAIN_BOUNDARY
!BOUNDARY_TYPE          BOX          ! rectangular box in GSM
DOMAIN_X_MAX           35.0         ! RE dayside
DOMAIN_X_MIN           -35.0        ! RE nightside
DOMAIN_Y_MAX           35.0         ! RE dusk
DOMAIN_Y_MIN           -35.0        ! RE dawn
DOMAIN_Z_MAX           35.0         ! RE north
DOMAIN_Z_MIN           -35.0        ! RE south
R_INNER                1.0          ! RE inner loss sphere

#ELECTRIC_FIELD
! No active electric-field keyword is used here.  The default validation state
! is a static magnetic dipole.
!COROTATION_E           NO
!CONV_E_MODEL           VOLLAND_STERN

!#TEMPORAL
!TEMPORAL_MODE          TIME_SERIES

#SPECTRUM
SPECTRUM_TYPE          POWER_LAW
SPEC_J0                1.00e+4
SPEC_GAMMA             3.50
SPEC_E0                10.0
SPEC_EMIN              1.0
SPEC_EMAX              1000.0

#OUTPUT_DOMAIN
OUTPUT_MODE            SHELLS
SHELL_COUNT            1
SHELL_ALTS_KM          9000.0
SHELL_RES_DEG          30

#OUTPUT_OPTIONS
!OUTPUT_CUTOFF          T
!OUTPUT_FORMAT          NETCDF4
!OUTPUT_COORDS          GEO

#NUMERICAL
! Parallel settings are supplied by run_C4.py via CLI:
!   -mode3d-mpi-scheduler <scheduler>
!   -mode3d-mpi-dynamic-chunk <chunk>
!   -mode3d-threads <nt>
!N_PARTICLES            10000
!MAX_BOUNCE             500
ADAPTIVE_DT            T            ! T: automatic gyro/boundary-limited dt; F: fixed DT_TRACE
DT_TRACE               0.25
MAX_TRACE_TIME         600
MAX_TRACE_DISTANCE     0.0

!#END
