#==============================================================================
# AMPS_PARAM_F2_gridless.in
# F2 — power-law energy integration
#
# PURPOSE
#   Validate the energy quadrature used for differential flux, integral flux,
#   and density in a case where transport is trivial and the imposed spectrum is
#   a known power law.  The validation-plan ENERGY_BINS are represented here as
#   #ENERGY_CHANNELS because that is the parser-compatible production syntax.
#==============================================================================

#RUN_INFO
  RUN_ID F2_power_law_energy_integration

#CALCULATION_MODE
  CALC_TARGET        DENSITY_SPECTRUM
  FIELD_EVAL_METHOD  GRIDLESS

#BACKGROUND_FIELD
  FIELD_MODEL        NONE
  EPOCH              2026-07-10T00:00:00

#ELECTRIC_FIELD
  EFIELD_MODEL       NONE

#DOMAIN_BOUNDARY
  DOMAIN_X_MIN      -10000.0   ! km
  DOMAIN_X_MAX       10000.0   ! km
  DOMAIN_Y_MIN      -10000.0   ! km
  DOMAIN_Y_MAX       10000.0   ! km
  DOMAIN_Z_MIN      -10000.0   ! km
  DOMAIN_Z_MAX       10000.0   ! km
  R_INNER                0.0   ! km; disable geometric loss for the normalization test

#PARTICLE_SPECIES
  SPECIES            PROTON
  CHARGE             1
  MASS_AMU           1.007276466621

#DENSITY_SPECTRUM
  DS_EMIN            1.0
  DS_EMAX            1000.0
  DS_NINTERVALS      960       ! fine log grid for analytical power-law integration
  DS_ENERGY_SPACING  LOG
  DS_BOUNDARY_MODE   ISOTROPIC
  DS_TRANSMISSION_MODE DIRECT
  DS_MAX_PARTICLES   0
  DS_MAX_TRAJ_TIME   5.0
  MODE3D_PARALLEL    THREADS
  MODE3D_THREADS     8
  GRIDLESS_MPI_SCHEDULER DYNAMIC
  GRIDLESS_MPI_DYNAMIC_CHUNK 0

#ENERGY_CHANNELS
  ! Validation-plan ENERGY_BINS: 1 3 10 30 100 300 1000 MeV
  CH_BEGIN
    BIN01_1_3        1.0      3.0
    BIN02_3_10       3.0     10.0
    BIN03_10_30     10.0     30.0
    BIN04_30_100    30.0    100.0
    BIN05_100_300  100.0    300.0
    BIN06_300_1000 300.0   1000.0
    FULL             1.0   1000.0
  CH_END

#SPECTRUM
  SPECTRUM_TYPE      POWER_LAW
  SPEC_J0            1.0
  SPEC_E0            10.0
  SPEC_GAMMA         3.5
  SPEC_EMIN          1.0
  SPEC_EMAX          1000.0

#NUMERICAL
  DT_TRACE           0.05
  ADAPTIVE_DT        T
  MAX_STEPS          20000
  MAX_TRACE_TIME     5.0
  MAX_TRACE_DISTANCE 0.0
  MODE3D_PARALLEL    THREADS
  MODE3D_THREADS     8
  GRIDLESS_MPI_SCHEDULER DYNAMIC
  GRIDLESS_MPI_DYNAMIC_CHUNK 0

#OUTPUT_DOMAIN
  OUTPUT_MODE POINTS
  POINTS_BEGIN
    POINT  1000.0     0.0     0.0
  POINTS_END
