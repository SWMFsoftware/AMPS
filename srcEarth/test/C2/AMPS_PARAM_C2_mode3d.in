! ═══════════════════════════════════════════════════════════════
! AMPS SEP geospace validation test C2
! Dipole longitude and north/south symmetry, Mode3D shells
!
! This input is intentionally kept close to the CCMC/RoR-style
! AMPS_PARAM_test.in file that is known to pass the current parser.
! Current-code validation controls such as UPPER_SCAN, scheduler,
! thread count, and Mode3D analytic-vs-grid field evaluation are passed
! by run_C2.py on the command line rather than stored as parser keywords
! here.  This keeps the input compatible with the stricter parser.
! ═══════════════════════════════════════════════════════════════

! ── Calculation mode ───────────────────────────────────────────
! CALC_TARGET: what the run computes.
! FIELD_EVAL_METHOD remains GRID_3D for Mode3D; run_C2.py passes
! -mode3d-field-eval ANALYTIC or MESH to select the trajectory-field backend.
#CALCULATION_MODE
CALC_TARGET            CUTOFF_RIGIDITY
FIELD_EVAL_METHOD      GRID_3D
!GRID_NX                100
!GRID_NY                100
!GRID_NZ                60
!GRID_XMIN              -35.0         ! RE GSM
!GRID_XMAX              35.0
!GRID_YMIN              -35.0
!GRID_YMAX              35.0
!GRID_ZMIN              -35.0
!GRID_ZMAX              35.0

! ── Cutoff rigidity scan ───────────────────────────────────────
! CUTOFF_SEARCH_ALGORITHM and CUTOFF_UPPER_SCAN_N are deliberately not
! active here.  run_C2.py supplies them via CLI:
!   -cutoff-search UPPER_SCAN -cutoff-upper-scan-n 80
#CUTOFF_RIGIDITY
CUTOFF_EMIN            1.0          ! MeV/n
CUTOFF_EMAX            20000.0      ! MeV/n
CUTOFF_MAX_PARTICLES   500          ! per injection point
CUTOFF_NENERGY         50           ! log-spaced energy bins
CUTOFF_SAMPLING        VERTICAL     ! VERTICAL or ISOTROPIC
CUTOFF_MAX_TRAJ_TIME   600.0! sec — max trajectory integration time

#PARTICLE_SPECIES
SPECIES                PROTON
CHARGE                 1            ! elementary charge
MASS_AMU               1.0073       ! atomic mass units

#BACKGROUND_FIELD
FIELD_MODEL            DIPOLE
DIPOLE_MOMENT          1.00         ! multiples of M_E
DIPOLE_TILT            0.0          ! deg from GSM Z-axis

#DOMAIN_BOUNDARY
!BOUNDARY_TYPE          BOX          ! rectangular box in GSM
DOMAIN_X_MAX           75.0         ! RE dayside
DOMAIN_X_MIN           -75.0        ! RE nightside
DOMAIN_Y_MAX           75.0         ! RE dusk
DOMAIN_Y_MIN           -75.0        ! RE dawn
DOMAIN_Z_MAX           75.0         ! RE north
DOMAIN_Z_MIN           -75.0        ! RE south
R_INNER                1.0          ! RE inner loss sphere

#ELECTRIC_FIELD
!COROTATION_E           NO           ! corotation = −(ω×r)×B
!CONV_E_MODEL           VOLLAND_STERN
!VS_KP                  AUTO
!VS_GAMMA               2.0
!VS_A                   0.78468
!VS_INPUT_MODE          OMNIWEB

!#TEMPORAL
!TEMPORAL_MODE          TIME_SERIES
!EVENT_START            2017-09-07T00:00
!EVENT_END              2017-09-10T20:00
!FIELD_UPDATE_DT        5
!INJECT_DT              30
!TS_INPUT_MODE          OMNIWEB

#SPECTRUM
SPECTRUM_TYPE          POWER_LAW
SPEC_J0                1.00e+4      ! p/cm2/s/sr/(MeV/n)
SPEC_GAMMA             3.50         ! spectral index
SPEC_E0                10.0         ! MeV/n pivot
SPEC_EMIN              1.0          ! MeV/n
SPEC_EMAX              1000.0       ! MeV/n

#OUTPUT_DOMAIN
OUTPUT_MODE            SHELLS
SHELL_COUNT            1
SHELL_ALTS_KM          9000.0
SHELL_RES_DEG          30

#OUTPUT_OPTIONS
!FLUX_TYPE              DIFFERENTIAL
!OUTPUT_CUTOFF          T
!OUTPUT_PITCH           F
!OUTPUT_FORMAT          NETCDF4
!OUTPUT_COORDS          GEO
!ENERGY_BINS            1 5 10 30 100 300 1000

#NUMERICAL
! Parallel settings are supplied by run_C2.py via CLI:
!   -mode3d-threads <nt>
!   -mode3d-mpi-scheduler <scheduler>
!   -mode3d-mpi-dynamic-chunk <chunk>
!N_PARTICLES            10000
!MAX_BOUNCE             500
DT_TRACE               1.0! s integration step
MAX_TRACE_TIME         600.0
MAX_TRACE_DISTANCE     300.0! Re; 0 disables cumulative distance cap

!#END

! ── C2 harness run-time settings, supplied through CLI ─────────
! C2_NT                  16
! C2_MPI_SCHEDULER       DYNAMIC
! C2_MPI_DYNAMIC_CHUNK   0
! C2_CUTOFF_SEARCH       UPPER_SCAN
! C2_CUTOFF_SCAN_N       80
