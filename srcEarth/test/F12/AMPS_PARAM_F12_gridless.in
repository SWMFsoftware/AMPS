#==============================================================================
# AMPS_PARAM_F12_gridless.in
# F12 — day/night spatial boundary anisotropy identities
#
# PURPOSE
#   Validate exact identities in the DAYSIDE_NIGHTSIDE spatial boundary-weight
#   model used by the gridless ANISOTROPIC density/spectrum path.
#
#   The runner renders this template for several BA_SPATIAL_MODEL / factor cases.
#   FIELD_MODEL NONE, R_INNER=0, and diagnostic points with X=0 make the access
#   geometry all-open and symmetric about the GSM Y-Z plane.  Therefore exactly
#   half of the deterministic direction grid exits through x_exit>0 and half
#   through x_exit<=0.
#
#   Exact references checked by run_F12.py:
#     1) DAYSIDE_NIGHTSIDE with factors (1,1) is identical to UNIFORM.
#     2) DAY_ONLY (1,0) and NIGHT_ONLY (0,1) each give 0.5 of UNIFORM.
#     3) DAY_ONLY + NIGHT_ONLY exactly reconstructs UNIFORM.
#     4) A weighted case, e.g. (2,0.5), gives ratio (2+0.5)/2 = 1.25.
#==============================================================================

#RUN_INFO
  RUN_ID F12_daynight_boundary_identity

#CALCULATION_MODE
  CALC_TARGET        DENSITY_SPECTRUM
  FIELD_EVAL_METHOD  GRIDLESS

#BACKGROUND_FIELD
  FIELD_MODEL        NONE
  EPOCH              2026-07-10T00:00:00

#ELECTRIC_FIELD
  EFIELD_MODEL       NONE

#DOMAIN_BOUNDARY
  DOMAIN_X_MIN      -10000.0   ! km
  DOMAIN_X_MAX       10000.0   ! km
  DOMAIN_Y_MIN      -10000.0   ! km
  DOMAIN_Y_MAX       10000.0   ! km
  DOMAIN_Z_MIN      -10000.0   ! km
  DOMAIN_Z_MAX       10000.0   ! km
  R_INNER                0.0   ! km; disable geometric loss for the symmetry test

#PARTICLE_SPECIES
  SPECIES            PROTON
  CHARGE             1
  MASS_AMU           1.007276466621

#DENSITY_SPECTRUM
  DS_EMIN            1.0
  DS_EMAX            1000.0
  DS_NINTERVALS      80
  DS_ENERGY_SPACING  LOG
  DS_BOUNDARY_MODE   ANISOTROPIC
  DS_TRANSMISSION_MODE DIRECT
  DS_TRANSMISSION_SAVE T
  DS_MAX_PARTICLES   0
  DS_MAX_TRAJ_TIME   5.0
  MODE3D_PARALLEL    THREADS
  MODE3D_THREADS     8
  GRIDLESS_MPI_SCHEDULER DYNAMIC
  GRIDLESS_MPI_DYNAMIC_CHUNK 0

#BOUNDARY_ANISOTROPY
  BA_PAD_MODEL        ISOTROPIC
  BA_PAD_EXPONENT     0.0
  BA_SPATIAL_MODEL    UNIFORM
  BA_DAYSIDE_FACTOR   1.0
  BA_NIGHTSIDE_FACTOR 1.0

#ENERGY_CHANNELS
  CH_BEGIN
    LOW       1.0     10.0
    MID      10.0    100.0
    HIGH    100.0   1000.0
    FULL      1.0   1000.0
  CH_END

#SPECTRUM
  SPECTRUM_TYPE      POWER_LAW
  SPEC_J0            1.0
  SPEC_E0            10.0
  SPEC_GAMMA         3.5
  SPEC_EMIN          1.0
  SPEC_EMAX          1000.0

#NUMERICAL
  DT_TRACE           0.05
  ADAPTIVE_DT        T
  MAX_STEPS          20000
  MAX_TRACE_TIME     5.0
  MAX_TRACE_DISTANCE 0.0
  MODE3D_PARALLEL    THREADS
  MODE3D_THREADS     8
  GRIDLESS_MPI_SCHEDULER DYNAMIC
  GRIDLESS_MPI_DYNAMIC_CHUNK 0

#OUTPUT_DOMAIN
  OUTPUT_MODE POINTS
  POINTS_BEGIN
    ! All diagnostic points have X=0, so dayside/nightside exits are paired.
    POINT     0.0  1000.0     0.0
    POINT     0.0 -1000.0     0.0
    POINT     0.0     0.0  1000.0
    POINT     0.0  1500.0   500.0
    POINT     0.0 -1500.0  -500.0
  POINTS_END
