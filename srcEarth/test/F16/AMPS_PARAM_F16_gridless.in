#==============================================================================
# AMPS_PARAM_F16_gridless.in
# F16 — blocked-access zero-flux regression
#
# PURPOSE
#   Validate the exact zero-access limit of the gridless density/spectrum path.
#   Every diagnostic point is deliberately placed inside the inner absorbing
#   sphere.  TraceAllowedImpl checks the inner loss sphere before taking the
#   first particle step, so every sampled direction and energy must be classified
#   as forbidden:
#
#       T(E) = 0
#       J_local(E) = T(E) J_boundary(E) = 0
#       n = 4*pi*int J_local(E)/v(E) dE = 0
#       F = 4*pi*int J_local(E) dE = 0
#
#   This test is useful for catching leakage through blocked locations, stale
#   transmission arrays, uninitialized flux channels, and sign/normalization bugs
#   in the zero-signal limit.
#==============================================================================

#RUN_INFO
  RUN_ID F16_blocked_access_zero_flux

#CALCULATION_MODE
  CALC_TARGET        DENSITY_SPECTRUM
  FIELD_EVAL_METHOD  GRIDLESS

#BACKGROUND_FIELD
  FIELD_MODEL        NONE
  EPOCH              2026-07-10T00:00:00

#ELECTRIC_FIELD
  EFIELD_MODEL       NONE

#DOMAIN_BOUNDARY
  DOMAIN_X_MIN      -10000.0   ! km
  DOMAIN_X_MAX       10000.0   ! km
  DOMAIN_Y_MIN      -10000.0   ! km
  DOMAIN_Y_MAX       10000.0   ! km
  DOMAIN_Z_MIN      -10000.0   ! km
  DOMAIN_Z_MAX       10000.0   ! km
  R_INNER             5000.0   ! km; all points below are intentionally inside

#PARTICLE_SPECIES
  SPECIES            PROTON
  CHARGE             1
  MASS_AMU           1.007276466621

#DENSITY_SPECTRUM
  DS_EMIN            1.0
  DS_EMAX            1000.0
  DS_NINTERVALS      80
  DS_ENERGY_SPACING  LOG
  DS_BOUNDARY_MODE   ISOTROPIC
  DS_TRANSMISSION_MODE DIRECT
  DS_TRANSMISSION_SAVE T
  DS_MAX_PARTICLES   0
  DS_MAX_TRAJ_TIME   5.0
  MODE3D_PARALLEL    THREADS
  MODE3D_THREADS     8
  GRIDLESS_MPI_SCHEDULER DYNAMIC
  GRIDLESS_MPI_DYNAMIC_CHUNK 0

#ENERGY_CHANNELS
  CH_BEGIN
    LOW       1.0     10.0
    MID      10.0    100.0
    HIGH    100.0   1000.0
    FULL      1.0   1000.0
  CH_END

#SPECTRUM
  SPECTRUM_TYPE      POWER_LAW
  SPEC_J0            1.0
  SPEC_E0            10.0
  SPEC_GAMMA         3.5
  SPEC_EMIN          1.0
  SPEC_EMAX          1000.0

#NUMERICAL
  DT_TRACE           0.05
  ADAPTIVE_DT        T
  MAX_STEPS          20000
  MAX_TRACE_TIME     5.0
  MAX_TRACE_DISTANCE 0.0
  MODE3D_PARALLEL    THREADS
  MODE3D_THREADS     8
  GRIDLESS_MPI_SCHEDULER DYNAMIC
  GRIDLESS_MPI_DYNAMIC_CHUNK 0

#OUTPUT_DOMAIN
  OUTPUT_MODE POINTS
  POINTS_BEGIN
    ! All points are inside R_INNER=5000 km by construction.
    POINT     0.0     0.0     0.0
    POINT  1000.0     0.0     0.0
    POINT -1000.0     0.0     0.0
    POINT     0.0  1000.0     0.0
    POINT     0.0 -1000.0     0.0
    POINT     0.0     0.0  1000.0
    POINT     0.0     0.0 -1000.0
    POINT  2000.0  1000.0 -500.0
  POINTS_END
