#==============================================================================
# AMPS_PARAM_F11_gridless.in
# F11 — anisotropic PAD model sum-check
#
# PURPOSE
#   Validate exact identities in the gridless anisotropic boundary-spectrum
#   implementation.  The runner renders this template for each requested
#   BA_PAD_MODEL / BA_PAD_EXPONENT case.
#
#   Exact references checked by run_F11.py:
#     1) BA_PAD_EXPONENT = 0 gives the isotropic result for every PAD model.
#     2) COSALPHA_N and BIDIRECTIONAL are mathematically identical for the same
#        exponent, because both use f_PAD(alpha)=|cos(alpha)|^n.
#==============================================================================

#RUN_INFO
  RUN_ID F11_pad_model_sum_check

#CALCULATION_MODE
  CALC_TARGET        DENSITY_SPECTRUM
  FIELD_EVAL_METHOD  GRIDLESS

#BACKGROUND_FIELD
  FIELD_MODEL        DIPOLE
  DIPOLE_MOMENT      1.0
  DIPOLE_TILT        0.0
  EPOCH              2026-07-10T00:00:00

#ELECTRIC_FIELD
  EFIELD_MODEL       NONE

#DOMAIN_BOUNDARY
  DOMAIN_X_MIN      -57340.8   ! km = -9 Re
  DOMAIN_X_MAX       57340.8   ! km =  9 Re
  DOMAIN_Y_MIN      -57340.8
  DOMAIN_Y_MAX       57340.8
  DOMAIN_Z_MIN      -57340.8
  DOMAIN_Z_MAX       57340.8
  R_INNER             6434.9   ! km = 1.01 Re

#PARTICLE_SPECIES
  SPECIES            PROTON
  CHARGE             1
  MASS_AMU           1.007276466621

#DENSITY_SPECTRUM
  DS_EMIN            5000.0
  DS_EMAX            50000.0
  DS_NINTERVALS      40
  DS_ENERGY_SPACING  LOG
  DS_BOUNDARY_MODE   ANISOTROPIC
  DS_TRANSMISSION_MODE SCAN
  DS_TRANSMISSION_SCAN_N 64
  DS_MAX_PARTICLES   0
  DS_MAX_TRAJ_TIME   600.0
  MODE3D_PARALLEL    THREADS
  MODE3D_THREADS     8
  GRIDLESS_MPI_SCHEDULER DYNAMIC
  GRIDLESS_MPI_DYNAMIC_CHUNK 0

#BOUNDARY_ANISOTROPY
  BA_PAD_MODEL        ISOTROPIC
  BA_PAD_EXPONENT     0.0
  BA_SPATIAL_MODEL    UNIFORM

#ENERGY_CHANNELS
  CH_BEGIN
    CH_LOW       5000.0    10000.0
    CH_HIGH     10000.0    50000.0
    CH_FULL      5000.0    50000.0
  CH_END

#SPECTRUM
  SPECTRUM_TYPE      POWER_LAW
  SPEC_J0            1.0e4
  SPEC_E0            10.0
  SPEC_GAMMA         3.5
  SPEC_EMIN          5000.0
  SPEC_EMAX          50000.0

#NUMERICAL
  DT_TRACE           0.5
  ADAPTIVE_DT        T
  MAX_STEPS          200000
  MAX_TRACE_TIME     600.0
  MAX_TRACE_DISTANCE 0.0
  MODE3D_PARALLEL    THREADS
  MODE3D_THREADS     8
  GRIDLESS_MPI_SCHEDULER DYNAMIC
  GRIDLESS_MPI_DYNAMIC_CHUNK 0

#OUTPUT_DOMAIN
  OUTPUT_MODE POINTS
  POINTS_BEGIN
    ! lon=0, lat=0, alt=9000 km; low-latitude geometry check
    POINT  15371.2       0.0        0.0
    ! lon=0, lat=-60, alt=9000 km; same diagnostic location family as C3/F4/F5
    POINT   7685.6       0.0   -13312.662
  POINTS_END
