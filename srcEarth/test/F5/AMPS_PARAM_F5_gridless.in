#==============================================================================
# AMPS_PARAM_F5_gridless.in
# F5 — directional anisotropy / PAD mapping
#
# PURPOSE
#   Validate the parser-supported anisotropic boundary PAD mapping in the
#   gridless density/spectrum solver for a nontrivial n=2 field-aligned beam.
#   The runner renders this template for ISOTROPIC, COSALPHA_N, and SINALPHA_N.
#
#   Primary exact check:
#       f_sin(alpha) + f_cos(alpha) = sin^2(alpha) + cos^2(alpha) = 1
#   so, for identical access trajectories and spectrum,
#       T_sin(E) + T_cos(E) = T_iso(E)
#       J_sin(E) + J_cos(E) = J_iso(E)
#       n_sin + n_cos = n_iso
#       F_sin + F_cos = F_iso
#
#   Secondary mapping check:
#       COSALPHA_N n=2 should enhance field-aligned/polar access relative to
#       equatorial access, while SINALPHA_N gives the complementary behavior.
#       run_F5.py compares density ratios to a high-energy straight-line
#       semi-analytic reference.
#==============================================================================

#RUN_INFO
  RUN_ID F5_pad_mapping

#CALCULATION_MODE
  CALC_TARGET        DENSITY_SPECTRUM
  FIELD_EVAL_METHOD  GRIDLESS

#BACKGROUND_FIELD
  FIELD_MODEL        DIPOLE
  DIPOLE_MOMENT      1.0
  DIPOLE_TILT        0.0
  EPOCH              2026-07-10T00:00:00

#ELECTRIC_FIELD
  EFIELD_MODEL       NONE

#DOMAIN_BOUNDARY
  DOMAIN_X_MIN      -57340.8   ! km = -9 Re
  DOMAIN_X_MAX       57340.8   ! km =  9 Re
  DOMAIN_Y_MIN      -57340.8
  DOMAIN_Y_MAX       57340.8
  DOMAIN_Z_MIN      -57340.8
  DOMAIN_Z_MAX       57340.8
  R_INNER             6434.9   ! km = 1.01 Re

#PARTICLE_SPECIES
  SPECIES            PROTON
  CHARGE             1
  MASS_AMU           1.007276466621

#DENSITY_SPECTRUM
  DS_EMIN            5000.0
  DS_EMAX            50000.0
  DS_NINTERVALS      64
  DS_ENERGY_SPACING  LOG
  DS_BOUNDARY_MODE   ANISOTROPIC
  DS_TRANSMISSION_MODE SCAN
  DS_TRANSMISSION_SCAN_N 96
  DS_MAX_PARTICLES   0
  DS_MAX_TRAJ_TIME   600.0
  MODE3D_PARALLEL    THREADS
  MODE3D_THREADS     8
  GRIDLESS_MPI_SCHEDULER DYNAMIC
  GRIDLESS_MPI_DYNAMIC_CHUNK 0

#BOUNDARY_ANISOTROPY
  BA_PAD_MODEL        ISOTROPIC
  BA_PAD_EXPONENT     2.0
  BA_SPATIAL_MODEL    UNIFORM

#ENERGY_CHANNELS
  CH_BEGIN
    CH_5_10GEV     5000.0   10000.0
    CH_10_20GEV   10000.0   20000.0
    CH_20_50GEV   20000.0   50000.0
    CH_FULL        5000.0   50000.0
  CH_END

#SPECTRUM
  SPECTRUM_TYPE      POWER_LAW
  SPEC_J0            1.0e4
  SPEC_E0            10.0
  SPEC_GAMMA         3.5
  SPEC_EMIN          5000.0
  SPEC_EMAX          50000.0

#NUMERICAL
  DT_TRACE           0.5
  ADAPTIVE_DT        T
  MAX_STEPS          200000
  MAX_TRACE_TIME     600.0
  MAX_TRACE_DISTANCE 0.0
  MODE3D_PARALLEL    THREADS
  MODE3D_THREADS     8
  GRIDLESS_MPI_SCHEDULER DYNAMIC
  GRIDLESS_MPI_DYNAMIC_CHUNK 0

#OUTPUT_DOMAIN
  OUTPUT_MODE POINTS
  POINTS_BEGIN
    ! TC_EQ8: 8 Re equator, GSM x-axis
    POINT  50969.6       0.0        0.0
    ! TC_PL8: 8 Re magnetic pole, +Z axis
    POINT      0.0       0.0    50969.6
    ! TC_EQ6: 6 Re equator, GSM x-axis; more stringent because rL/domain is smaller
    POINT  38227.2       0.0        0.0
  POINTS_END
