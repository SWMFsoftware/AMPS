#==============================================================================
# test_density_dipole_4pts.in
# AMPS_PARAM input file вЂ” Analytic density/spectrum test cases
#
# PURPOSE
#   Run the gridless density/spectrum solver at four carefully chosen
#   observation points where the analytic expected density is known exactly
#   (TC1вЂ“TC3) or bounded above (TC4). All tests use a DIPOLE magnetic field
#   so that StГёrmer theory provides the analytic cutoff predictions.
#
# COMPANION SCRIPT
#   test_density_analytic.py вЂ” reads the AMPS output files and compares
#   each point against its analytic prediction.
#
# PHYSICS SUMMARY (see README_density_tests.md for full derivation)
#
#   The solver computes:
#     J_loc(E; x0) = T(E; x0) * J_b(E)
#     n_tot(x0)    = 4pi * int[Emin,Emax] T(E;x0) * J_b(E) / v(E) dE
#
#   where T = fraction of backtraced trajectories that escape the outer box.
#
#   For locations where ALL energies are above the maximum StГёrmer cutoff:
#     T(E; x0) = T_geo(r)  for all E
#     T_geo(r) = (1 + sqrt(1 - (r_inner/r)^2)) / 2
#     n_tot    = T_geo * 4pi * int J_b(E)/v(E) dE     [EXACT ANALYTIC]
#
#   TEST CASES (DIPOLE, r_inner=1.01 Re, outer box 9 Re):
#
#   TC1 вЂ” (8Re, 0, 0) equator, E=2вЂ“20 GeV
#     Rc_max(8Re)=0.93 GV в†’ 384 MeV;  all E >> Rc_max  в†’  T = T_geo = 0.9960
#     n_expected = 1.9234e-03 m^-3
#
#   TC2 вЂ” (0, 0, 5Re) magnetic pole, E=50вЂ“500 MeV
#     Pole: cos(lam)=0 в†’ StГёrmer Rc=0 for ALL directions в†’ T = T_geo = 0.9897
#     n_expected = 1.7751e-01 m^-3
#
#   TC3 вЂ” (6Re, 0, 0) equator, E=3вЂ“30 GeV
#     Rc_max(6Re)=1.66 GV в†’ 965 MeV;  all E >> Rc_max  в†’  T = T_geo = 0.9929
#     n_expected = 1.2639e-03 m^-3
#
#   TC4 вЂ” (2Re, 0, 0) equator, E=10вЂ“500 MeV
#     Rc_vert(2Re)=3.73 GV;  R(500MeV)=1.09 GV << Rc_vert  в†’  deep shielding
#     n_model << T_geo * n_free = 1.81e+00 m^-3   [UPPER BOUND TEST only]
#
# IMPORTANT: The energy ranges of TC1, TC2, TC3, TC4 differ. This single
# input file uses a UNIFIED energy grid spanning 10 MeV вЂ“ 20 GeV. The
# comparison script integrates only over the relevant sub-range for each
# test. The transmissivity T(E) per energy bin is read from the spectrum
# output file.
#
# See README_density_tests.md for:
#   - StГёrmer cutoff formula derivation
#   - Geometric shadow derivation
#   - Effect of Earth's inner boundary on the density estimate
#   - Tolerances and expected deviations
#==============================================================================

#CALCULATION_MODE
  CALC_TARGET        DENSITY_SPECTRUM
  FIELD_EVAL_METHOD  GRIDLESS

#BACKGROUND_FIELD
  FIELD_MODEL        DIPOLE
  DIPOLE_MOMENT      1.0       ! multiples of M_E  (B_eq(Re) = 3.12e-5 T)
  DIPOLE_TILT        0.0       ! degrees; 0 = dipole axis aligned with +Z_GSM

#DOMAIN_BOUNDARY
  DOMAIN_X_MAX       57340.8   ! km = 9.0 Re  (outer box, dayside)
  DOMAIN_X_MIN      -57340.8   ! km = -9.0 Re (outer box, nightside)
  DOMAIN_Y_MAX       57340.8   ! km = 9.0 Re
  DOMAIN_Y_MIN      -57340.8   ! km = -9.0 Re
  DOMAIN_Z_MAX       57340.8   ! km = 9.0 Re
  DOMAIN_Z_MIN      -57340.8   ! km = -9.0 Re
  R_INNER            6434.9    ! km = 1.01 Re  (inner loss sphere)

#DENSITY_SPECTRUM
  DS_EMIN            10.0      ! MeV вЂ” lower bound (TC2 needs 50+, TC4 needs 10+)
  DS_EMAX            20000.0   ! MeV = 20 GeV вЂ” upper bound (TC1 needs up to 20 GeV)
  DS_NINTERVALS      60        ! 61 log-spaced energy points over 3 decades
  DS_ENERGY_SPACING  LOG
  DS_BOUNDARY_MODE   ISOTROPIC

#SPECTRUM
  ! Power-law differential intensity: J_b(E) = J0 * (E/E0)^(-GAMMA)
  ! Units as registered by the solver: J0 in m^-2 s^-1 sr^-1 MeV^-1
  !
  ! IMPORTANT: Verify that these key names match your spectrum.h
  ! InitGlobalSpectrumFromKeyValueMap() implementation. Common alternatives:
  !   SPECTRAL_INDEX instead of GAMMA
  !   E_REFERENCE instead of E0_MEV
  !   J_REFERENCE instead of J0
  !
  SPECTRUM_TYPE      POWER_LAW
  J0                 10000.0   ! m^-2 s^-1 sr^-1 MeV^-1  (= 1 cm^-2 s^-1 sr^-1 MeV^-1)
  E0_MEV             100.0     ! MeV  reference energy
  GAMMA              2.0       ! spectral index (J proportional to E^-GAMMA)

#NUMERICAL
  DT_TRACE           0.5       ! s вЂ” initial time step for particle integration
  MAX_STEPS          200000    ! hard cap on integration steps per trajectory
  MAX_TRACE_TIME     600.0     ! s вЂ” hard cap on integration time per trajectory

#OUTPUT_DOMAIN
  OUTPUT_MODE   POINTS

  POINTS_BEGIN
  !  X_km        Y_km    Z_km     Description
  !  -------     ------  -----    -----------------------------------------------
    50969.6      0.0     0.0      ! TC1: 8 Re equator  вЂ” above-cutoff free space
        0.0      0.0  31856.0     ! TC2: 5 Re pole     вЂ” magnetic pole, Rc=0
    38227.2      0.0     0.0      ! TC3: 6 Re equator  вЂ” above-cutoff, closer-in
    12742.4      0.0     0.0      ! TC4: 2 Re equator  вЂ” deep StГёrmer shielding
  POINTS_END
