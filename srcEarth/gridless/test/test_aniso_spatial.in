#==============================================================================
# test_aniso_spatial.in
# Anisotropic spatial: DAYSIDE_NIGHTSIDE (exact analytic ratio = 1.25)
#==============================================================================
! EXPECTED BEHAVIOUR
! --------------------
! The observation point (0, 8Re, 0) lies on the GSM Y-axis (dusk meridian).
! By the left-right symmetry of the domain box about the GSM Y-Z plane,
! exactly half the allowed exit points have x_exit > 0 (dayside) and half x_exit < 0.
!
! Therefore the solid-angle-averaged spatial weight is EXACTLY:
!   <f_spatial> = (f_day + f_night) / 2 = (2.0 + 0.5) / 2 = 1.25
!
! And:
!   n_aniso / n_iso = <f_spatial> = 1.25   [EXACT ANALYTIC, no approximation]
!
! This test is independent of the PAD model and independent of the
! straight-line approximation. The 1.25 prediction is exact by symmetry.
!
! Companion script: python3 test_density_aniso.py

#CALCULATION_MODE
  CALC_TARGET        DENSITY_SPECTRUM
  FIELD_EVAL_METHOD  GRIDLESS

#BACKGROUND_FIELD
  FIELD_MODEL        DIPOLE
  DIPOLE_MOMENT      1.0
  DIPOLE_TILT        0.0

#DOMAIN_BOUNDARY
  DOMAIN_X_MAX       57340.8   ! km =  9.0 Re
  DOMAIN_X_MIN      -57340.8   ! km = -9.0 Re
  DOMAIN_Y_MAX       57340.8   ! km =  9.0 Re
  DOMAIN_Y_MIN      -57340.8   ! km = -9.0 Re
  DOMAIN_Z_MAX       57340.8   ! km =  9.0 Re
  DOMAIN_Z_MIN      -57340.8   ! km = -9.0 Re
  R_INNER            6434.9    ! km = 1.01 Re

#DENSITY_SPECTRUM
  DS_EMIN            5000.0    ! MeV = 5 GeV  [rL > 21 Re at all 3 points >> 9 Re domain]
  DS_EMAX            50000.0   ! MeV = 50 GeV
  DS_NINTERVALS      40        ! 41 log-spaced bins
  DS_ENERGY_SPACING  LOG

#SPECTRUM
  SPECTRUM_TYPE      POWER_LAW
  J0                 10000.0   ! m^-2 s^-1 sr^-1 MeV^-1
  E0_MEV             100.0
  GAMMA              2.0

#NUMERICAL
  DT_TRACE           0.5
  MAX_STEPS          200000
  MAX_TRACE_TIME     600.0

  DS_BOUNDARY_MODE   ANISOTROPIC

#BOUNDARY_ANISOTROPY
  BA_PAD_MODEL        ISOTROPIC     ! no PAD anisotropy — isolates spatial effect
  BA_PAD_EXPONENT     2.0
  BA_SPATIAL_MODEL    DAYSIDE_NIGHTSIDE
  BA_DAYSIDE_FACTOR   2.0           ! dayside (GSM x_exit > 0) flux multiplier
  BA_NIGHTSIDE_FACTOR 0.5           ! nightside (GSM x_exit <= 0) flux multiplier

#OUTPUT_DOMAIN
  OUTPUT_MODE   POINTS
  POINTS_BEGIN
  !  X_km         Y_km      Z_km      Description
        0.0   50969.6       0.0       ! TC-DUSK: 8 Re dusk meridian (GSM Y-axis)
  POINTS_END
