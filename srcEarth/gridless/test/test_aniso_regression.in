#==============================================================================
# test_aniso_regression.in
# Anisotropic regression: ISOTROPIC PAD (must reproduce isotropic density)
#==============================================================================
! EXPECTED BEHAVIOUR
! --------------------
! With BA_PAD_MODEL=ISOTROPIC, every trajectory weight is f_PAD=1 and f_spatial=1.
! The anisotropic transmissivity reduces exactly to the isotropic transmissivity:
!   T_aniso(E;x0) = (1/N_dirs) * sum_k A_k * 1 * 1 = T_iso(E;x0)
! Therefore n_aniso should equal n_iso to within directional-sampling statistics (~1%).
!
! Reference n_iso (5-50 GeV, power-law gamma=2, J0=1e4 m-2 s-1 sr-1 MeV-1):
!   8Re equator: n_iso = T_geo(8Re) * n_free = 0.99598 * n_free
!   8Re pole:    n_iso = T_geo(8Re) * n_free = 0.99500 * n_free
!   6Re equator: n_iso = T_geo(6Re) * n_free = 0.99287 * n_free
!
! Companion script: python3 test_density_aniso.py

#CALCULATION_MODE
  CALC_TARGET        DENSITY_SPECTRUM
  FIELD_EVAL_METHOD  GRIDLESS

#BACKGROUND_FIELD
  FIELD_MODEL        DIPOLE
  DIPOLE_MOMENT      1.0
  DIPOLE_TILT        0.0

#DOMAIN_BOUNDARY
  DOMAIN_X_MAX       57340.8   ! km =  9.0 Re
  DOMAIN_X_MIN      -57340.8   ! km = -9.0 Re
  DOMAIN_Y_MAX       57340.8   ! km =  9.0 Re
  DOMAIN_Y_MIN      -57340.8   ! km = -9.0 Re
  DOMAIN_Z_MAX       57340.8   ! km =  9.0 Re
  DOMAIN_Z_MIN      -57340.8   ! km = -9.0 Re
  R_INNER            6434.9    ! km = 1.01 Re

#DENSITY_SPECTRUM
  DS_EMIN            5000.0    ! MeV = 5 GeV  [rL > 21 Re at all 3 points >> 9 Re domain]
  DS_EMAX            50000.0   ! MeV = 50 GeV
  DS_NINTERVALS      40        ! 41 log-spaced bins
  DS_ENERGY_SPACING  LOG

#SPECTRUM
  ! Power-law differential intensity: J_b(E) = J0 * (E/E0)^(-GAMMA)
  ! Units as registered by the solver: J0 in m^-2 s^-1 sr^-1 MeV^-1
  !
  ! IMPORTANT: Verify that these key names match your spectrum.h
  ! InitGlobalSpectrumFromKeyValueMap() implementation. Common alternatives:
  !   SPECTRAL_INDEX instead of GAMMA
  !   E_REFERENCE instead of E0_MEV
  !   J_REFERENCE instead of J0
  !
  SPECTRUM_TYPE      POWER_LAW
  SPEC_J0                1.00e+4   ! p/cm2/s/sr/(MeV/n)
  SPEC_GAMMA             3.50         ! spectral index
  SPEC_E0                10.0          ! MeV/n pivot
  SPEC_EMIN              1.0          ! MeV/n
  SPEC_EMAX              20000.0       ! MeV/n

#NUMERICAL
  DT_TRACE           0.5
  MAX_STEPS          200000
  MAX_TRACE_TIME     600.0

  DS_BOUNDARY_MODE   ANISOTROPIC

#BOUNDARY_ANISOTROPY
  BA_PAD_MODEL        ISOTROPIC     ! identity PAD: f(alpha)=1 -> n_aniso must equal n_iso
  BA_PAD_EXPONENT     2.0           ! not used for ISOTROPIC; kept for parser completeness
  BA_SPATIAL_MODEL    UNIFORM       ! f_spatial=1 everywhere

#OUTPUT_DOMAIN
  OUTPUT_MODE   POINTS
  POINTS_BEGIN
  !  X_km         Y_km      Z_km      Description
  POINT  50969.6       0.0       0.0       ! TC-EQ8: 8 Re equator (GSM x-axis)
  POINT      0.0       0.0   50969.6       ! TC-PL8: 8 Re magnetic pole (+Z)
  POINT  38227.2       0.0       0.0       ! TC-EQ6: 6 Re equator
  POINTS_END
