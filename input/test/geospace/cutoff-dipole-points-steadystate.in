! ═══════════════════════════════════════════════════════════════
! AMPS_PARAM.in — generated by CCMC Runs-on-Request interface
! Run: SEP_Sep2017_VanAllenProbeA
! ═══════════════════════════════════════════════════════════════

#RUN_INFO
RUN_ID                 SEP_Sep2017_VanAllenProbeA
PI_NAME                Unknown
PI_EMAIL               unknown@unknown.edu
SCIENCE_GOAL           storm_validation

! ── Calculation mode (Step 2) ──────────────────────────────────
! CALC_TARGET: what the run computes (cutoff rigidity or flux).
! FIELD_EVAL_METHOD: how B/E are evaluated (analytic vs grid interpolation).
! GRID_* keywords are only emitted when FIELD_EVAL_METHOD = GRID_3D.
#CALCULATION_MODE
CALC_TARGET            CUTOFF_RIGIDITY
FIELD_EVAL_METHOD      GRIDLESS


! ── Cutoff rigidity scan (Step 2, Section C) ───────────────────
! Energy range and particle budget for backward-tracing cutoff search.
#CUTOFF_RIGIDITY
CUTOFF_EMIN            1.0          ! MeV/n
CUTOFF_EMAX            20000.0       ! MeV/n
CUTOFF_MAX_PARTICLES   500              ! per injection point
CUTOFF_NENERGY         50               ! log-spaced energy bins
CUTOFF_MAX_TRAJ_TIME   600               ! sec — max trajectory integration time
CUTOFF_SAMPLING        VERTICAL           ! VERTICAL or ISOTROPIC
DIRECTIONAL_MAP        T                 ! compute directional Rc sky-map
DIRMAP_LON_RES         10                ! deg — longitude resolution
DIRMAP_LAT_RES         10                ! deg — latitude resolution



#PARTICLE_SPECIES
SPECIES                PROTON
CHARGE                 1               ! elementary charge
MASS_AMU               1.0073           ! atomic mass units

#BACKGROUND_FIELD
FIELD_MODEL            DIPOLE
DIPOLE_MOMENT          1.00         ! multiples of M_E
DIPOLE_TILT            0.0          ! deg from GSM Z-axis

#DOMAIN_BOUNDARY
BOUNDARY_TYPE          BOX  ! rectangular box in GSM
DOMAIN_X_MAX           15.0         ! RE dayside
DOMAIN_X_MIN           -60.0        ! RE nightside
DOMAIN_Y_MAX           25.0         ! RE dusk
DOMAIN_Y_MIN           -25.0        ! RE dawn
DOMAIN_Z_MAX           20.0         ! RE north
DOMAIN_Z_MIN           -20.0        ! RE south
R_INNER                1.0           ! RE inner loss sphere

#TEMPORAL
TEMPORAL_MODE          STEADY_STATE
EPOCH                  2017-09-10T16:00

#SPECTRUM
SPECTRUM_TYPE          POWER_LAW
SPEC_J0                1.00e+4   ! p/cm2/s/sr/(MeV/n)
SPEC_GAMMA             3.50         ! spectral index
SPEC_E0                10.0          ! MeV/n pivot
SPEC_EMIN              1.0          ! MeV/n
SPEC_EMAX              1000.0       ! MeV/n

#OUTPUT_DOMAIN
OUTPUT_MODE            POINTS
FLUX_DT                1.0           ! min (trajectory cadence; ignored for POINTS/SHELLS)
N_POINTS               2                 ! number of points provided below
POINTS_BEGIN
POINT                 7000 0 0
POINT                 9000 0 0
POINTS_END

#OUTPUT_OPTIONS
FLUX_TYPE              DIFFERENTIAL
OUTPUT_CUTOFF          T                    ! cutoff rigidity maps
OUTPUT_PITCH           F                    ! pitch angle distributions
OUTPUT_FORMAT          NETCDF4
OUTPUT_COORDS          GEO
ENERGY_BINS            1 5 10 30 100 300 1000   ! MeV/n

#NUMERICAL
N_PARTICLES            10000              ! test particles per injection
MAX_BOUNCE             500                ! max mirror reflections
DT_TRACE               10.0               ! s integration step
PITCH_ISOTROPIC        T                 ! isotropic injection

#END
