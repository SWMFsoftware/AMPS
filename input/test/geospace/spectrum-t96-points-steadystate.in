! ═══════════════════════════════════════════════════════════════
! AMPS_PARAM.in — generated by CCMC Runs-on-Request interface
! Run: SEP_Sep2017_VanAllenProbeA
! ═══════════════════════════════════════════════════════════════

#RUN_INFO
RUN_ID                 SEP_Sep2017_VanAllenProbeA
PI_NAME                Unknown
PI_EMAIL               unknown@unknown.edu
SCIENCE_GOAL           storm_validation

! ── Calculation mode (Step 2) ──────────────────────────────────
! CALC_TARGET: what the run computes (cutoff rigidity or flux).
! FIELD_EVAL_METHOD: how B/E are evaluated (analytic vs grid interpolation).
! GRID_* keywords are only emitted when FIELD_EVAL_METHOD = GRID_3D.
#CALCULATION_MODE
CALC_TARGET            DENSITY_SPECTRUM
FIELD_EVAL_METHOD      GRIDLESS



! ── Density & spectrum sampling (Step 2, Section D) ───────────────
! Backward-trace energy grid + boundary spectrum folding.
#DENSITY_SPECTRUM
DS_EMIN                1.0          ! MeV/n
DS_EMAX                1000.0       ! MeV/n
DS_NINTERVALS          50               ! energy intervals
DS_MAX_PARTICLES       500              ! per observation point
DS_ENERGY_SPACING      LOG           ! LOG or LINEAR


#PARTICLE_SPECIES
SPECIES                PROTON
CHARGE                 1               ! elementary charge
MASS_AMU               1.0073           ! atomic mass units

#BACKGROUND_FIELD
FIELD_MODEL            T96
DST                    -142.0         ! nT ring current index (Dst)
PDYN                   3.50          ! nPa solar-wind dynamic pressure
IMF_BZ                 -18.50         ! nT IMF Bz (GSM)
SW_VX                  -650.0       ! km/s solar-wind Vx
SW_N                   12.00         ! cm-3 solar-wind proton density
IMF_BY                 3.20          ! nT IMF By
IMF_BX                 0.00          ! nT IMF Bx
EPOCH                  2017-09-10T16:00  ! UTC snapshot
! TS05 advanced inputs (optional; for reproducibility / TS05 W-variable runs)
! TS05_TILT_RAD          0.0000
! TS05_IMFFLAG           1
! TS05_ISWFLAG           1
! TS05_W1                
! TS05_W2                
! TS05_W3                
! TS05_W4                
! TS05_W5                
! TS05_W6                

! T96_TILT_DEG           0.0
! T01_TILT_DEG           0.0
! T01_G1                 0.0
! T01_G2                 0.0
! T01_EPOCH              2017-09-10T16:00

! TA15 (optional full driver set; official OMNI-style inputs)
! TA15_BX_GSW            0.00
! TA15_BY_GSW            0.00
! TA15_BZ_GSW            2.00
! TA15_VX_GSE            -450.0
! TA15_VY_GSE            0.0
! TA15_VZ_GSE            0.0
! TA15_NP                5.00
! TA15_T_K               200000
! TA15_SYMH              -20.0
! TA15_IMF_FLAG          1
! TA15_SW_FLAG           1
! TA15_TILT_RAD          0.0000
! TA15_PDYN              2.00
! TA15_N_INDEX           0.2500
! TA15_B_INDEX           0.2500
! TA15_EPOCH             2017-09-10T16:00

! TA16RBF (optional full driver set; TA16 OMNI-style inputs + SymHc)
! TA16_BX_GSW            0.00
! TA16_BY_GSW            0.00
! TA16_BZ_GSW            2.00
! TA16_VX_GSE            -450.0
! TA16_VY_GSE            0.0
! TA16_VZ_GSE            0.0
! TA16_NP                5.00
! TA16_T_K               200000
! TA16_SYMH              -20.0
! TA16_IMF_FLAG          1
! TA16_SW_FLAG           1
! TA16_TILT_RAD          0.0000
! TA16_PDYN              2.00
! TA16_N_INDEX           0.2500
! TA16_B_INDEX           0.2500
! TA16_SYMHC             -20.0
! TA16_EPOCH             2017-09-10T16:00

#DOMAIN_BOUNDARY
BOUNDARY_TYPE          BOX  ! rectangular box in GSM
DOMAIN_X_MAX           15.0         ! RE dayside
DOMAIN_X_MIN           -60.0        ! RE nightside
DOMAIN_Y_MAX           25.0         ! RE dusk
DOMAIN_Y_MIN           -25.0        ! RE dawn
DOMAIN_Z_MAX           20.0         ! RE north
DOMAIN_Z_MIN           -20.0        ! RE south
R_INNER                2.0           ! RE inner loss sphere

#TEMPORAL
TEMPORAL_MODE          STEADY_STATE
EPOCH                  2017-09-10T16:00

#SPECTRUM
SPECTRUM_TYPE          POWER_LAW
SPEC_J0                1.00e+4   ! p/cm2/s/sr/(MeV/n)
SPEC_GAMMA             3.50         ! spectral index
SPEC_E0                10.0          ! MeV/n pivot
SPEC_EMIN              1.0          ! MeV/n
SPEC_EMAX              1000.0       ! MeV/n

#OUTPUT_DOMAIN
OUTPUT_MODE            POINTS
FLUX_DT                1.0           ! min (trajectory cadence; ignored for POINTS/SHELLS)
N_POINTS               2                 ! number of points provided below
POINTS_BEGIN
POINT                 7000 0 0
POINT                 9000 0 0
POINTS_END

#OUTPUT_OPTIONS
FLUX_TYPE              DIFFERENTIAL
OUTPUT_CUTOFF          T                    ! cutoff rigidity maps
OUTPUT_PITCH           F                    ! pitch angle distributions
OUTPUT_FORMAT          NETCDF4
OUTPUT_COORDS          GEO
ENERGY_BINS            1 5 10 30 100 300 1000   ! MeV/n

#NUMERICAL
N_PARTICLES            10000              ! test particles per injection
MAX_BOUNCE             500                ! max mirror reflections
DT_TRACE               1.0               ! s integration step
PITCH_ISOTROPIC        T                 ! isotropic injection

#END